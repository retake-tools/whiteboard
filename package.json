{
  "name": "@retake-tools/whiteboard",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/retake-tools/whiteboard.git"
  },
  "homepage": "https://github.com/retake-tools/whiteboard#readme",
  "bugs": {
    "url": "https://github.com/retake-tools/whiteboard/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 18770",
    "dev:local": "vite --host 127.0.0.1 --port 18770",
    "build": "tsc --noEmit && vite build",
    "codex:install": "node scripts/install-codex-plugin.mjs",
    "codex:e2e:prepare": "tsx server/codex-e2e-prepare.ts",
    "cancellation:test": "tsx server/execution-cancellation-contract-test.ts",
    "mcp": "node ./node_modules/tsx/dist/cli.mjs server/mcp-server.ts",
    "mcp:binding-guard": "RETAKE_WORKSPACE_DIR=.retake-test tsx server/mcp-binding-guard-test.ts",
    "mcp:execution-status": "RETAKE_WORKSPACE_DIR=.retake-test tsx server/mcp-execution-status-test.ts",
    "mcp:existing-execution": "RETAKE_WORKSPACE_DIR=.retake-test tsx server/mcp-existing-execution-smoke-test.ts",
    "mcp:import-smoke": "RETAKE_WORKSPACE_DIR=.retake-test tsx server/mcp-import-smoke-test.ts",
    "mcp:multi-result": "RETAKE_WORKSPACE_DIR=.retake-test tsx server/mcp-multi-result-smoke-test.ts",
    "mcp:smoke": "RETAKE_WORKSPACE_DIR=.retake-test tsx server/mcp-smoke-test.ts",
    "mcp:test": "npm run sizing:test && npm run grouping:test && npm run group-ui:test && npm run popover:test && npm run hydration:test && npm run view-state:test && npm run snapshot-safety:test && npm run result-branch:test && npm run profiles:test && npm run roles:test && npm run local-image:test && npm run annotation:test && npm run cancellation:test && npm run mcp:binding-guard && npm run mcp:execution-status && npm run mcp:smoke && npm run mcp:import-smoke && npm run mcp:multi-result && npm run mcp:existing-execution",
    "plugin:package:test": "node scripts/codex-plugin-package-test.mjs",
    "hydration:test": "tsx server/board-hydration-contract-test.ts",
    "view-state:test": "tsx server/board-view-state-contract-test.ts",
    "annotation:test": "tsx server/image-annotation-contract-test.ts",
    "local-image:test": "tsx server/local-image-adjustment-contract-test.ts",
    "popover:test": "tsx server/popover-dismissal-contract-test.ts",
    "production": "npm run build && npm run production:preview",
    "production:preview": "vite preview --host 127.0.0.1 --port 18771",
    "preview": "vite preview --host 127.0.0.1 --port 18771",
    "preview:local": "npm run preview",
    "profiles:test": "tsx server/generation-profile-contract-test.ts",
    "result-branch:test": "tsx server/result-branch-contract-test.ts",
    "grouping:test": "tsx server/grouping-contract-test.ts",
    "group-ui:test": "tsx server/group-inspector-render-test.tsx",
    "roles:test": "tsx server/input-role-contract-test.ts",
    "snapshot-safety:test": "RETAKE_WORKSPACE_DIR=.retake-test tsx server/snapshot-persistence-safety-test.ts",
    "sizing:test": "tsx server/block-sizing-contract-test.ts",
    "skill:validate": "node scripts/validate-codex-skill.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xyflow/react": "12.11.1",
    "lucide-react": "1.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "6.0.3",
    "vite": "8.1.2"
  }
}
